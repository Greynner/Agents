{
  "name": "qa-agent",
  "version": "1.0.0",
  "description": "QA AI Agent with Doppler integration and automation scripts",
  "scripts": {
    "start": "doppler run -- python main.py",
    "dev": "doppler run -- uvicorn main:app --reload",
    "test": "doppler run -- python test_doppler.py",
    "lint": "black .",
    "deploy": "echo '🚀 Ready to deploy to Vercel or Modal'",
    "src:app": "doppler run -- streamlit run src/app.py",
    "src:app-hannah": "doppler run -- streamlit run src/app_hannah_error_handling.py",
    "src:app-ms": "doppler run -- streamlit run src/app_ms_agent.py",
    "src:main": "doppler run -- python src/main.py",
    "src:test": "doppler run -- python src/test_doppler_src.py",
    "src:modal": "doppler run -- python src/modal_app.py",
    "hannah:modal": "doppler run -- python src/hannah_modal_app.py",
    "modal:test": "doppler run -- python src/modal_app.py",
    "modal:deploy": "doppler run -- modal deploy src/modal_app.py",
    "hannah:deploy": "doppler run -- modal deploy src/hannah_modal_app.py",
    "hannah:run": "doppler run -- modal run -m src.hannah_modal_app --requirement"
  },
  "author": "Greynner Moreno",
  "license": "MIT"
}
